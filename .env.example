# ===========================================
# 后端环境变量配置示例
# 在 Railway 或其他部署平台中配置这些变量
# ===========================================

# ========== 数据库配置 ==========
# MySQL 连接 URL (格式: jdbc:mysql://host:port/database?params)
SPRING_DATASOURCE_URL=jdbc:mysql://your-mysql-host:3306/waterbody?characterEncoding=UTF-8&useUnicode=true&useSSL=false&tinyInt1isBit=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai

# MySQL 用户名
MYSQLUSER=your_mysql_username

# MySQL 密码
MYSQLPASSWORD=your_mysql_password

# ========== Redis 配置 ==========
# Redis 主机地址
REDISHOST=your_redis_host

# Redis 端口
REDISPORT=6379

# Redis 密码 (如无密码则留空)
REDIS_PASSWORD=

# ========== MQTT 配置 ==========
# MQTT 服务器地址 (格式: tcp://host:port)
MQTT_HOST=tcp://your_mqtt_host:1883

# MQTT 用户名
MQTT_USERNAME=admin

# MQTT 密码
MQTT_PASSWORD=your_mqtt_password

# ========== 邮件服务配置 ==========
# SMTP 服务器地址
MAIL_HOST=smtp.qq.com

# 邮箱账号
MAIL_USERNAME=your_email@qq.com

# 邮箱授权码/密码
MAIL_PASSWORD=your_email_password

# ========== 阿里云 OSS 配置 ==========
# OSS Endpoint
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com

# OSS AccessKey ID
OSS_ACCESS_KEY_ID=your_access_key_id

# OSS AccessKey Secret
OSS_ACCESS_KEY_SECRET=your_access_key_secret

# OSS Bucket 名称
OSS_BUCKET_NAME=waterbody
