<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.blackwater.dao.WaterDataDao">



    <select id="selectTemperatureWeekBySite" resultType="com.blackwater.entity.Water.WaterTemperatureWeek">
        select t1,t2,t3,t4,t5,t6,t7
        from water_data
        where site_id =  #{site};
    </select>
    <select id="selectAmountWeekBySite" resultType="com.blackwater.entity.Water.WaterAmountWeek">
        select a1,a2,a3,a4,a5,a6,a7
        from water_data
        where site_id =  #{site};
    </select>
    <select id="selectPhWeekBySite" resultType="com.blackwater.entity.Water.WaterPhWeek">
        select p1,p2,p3,p4,p5,p6,p7
        from water_data
        where site_id =  #{site};
    </select>
    <select id="selectWaterBySite" resultType="com.blackwater.entity.Water.WaterData">
        select *
        from water_data;
    </select>
</mapper>